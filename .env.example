# Environment Variables Configuration

# Django Settings
DEBUG=True
SECRET_KEY=django-insecure-your-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (use different settings for production)
# SQLite (development)
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3

# MySQL (production example)
# DATABASE_ENGINE=django.db.backends.mysql
# DATABASE_NAME=boutique_db
# DATABASE_USER=root
# DATABASE_PASSWORD=password
# DATABASE_HOST=localhost
# DATABASE_PORT=3306

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000

# File Upload
MAX_UPLOAD_SIZE=5242880

# Email (optional, for password reset)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# AWS S3 (optional, for production media storage)
# USE_S3=True
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=boutique-store

# Frontend API URL
REACT_APP_API_URL=http://localhost:8000/api
